<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>@htakeuchi cheatsheet</title>
  <meta name="description" content="cheatsheets" >

  <link rel="stylesheet" href="https://unpkg.com/bulmaswatch/cerulean/bulmaswatch.min.css">
  <link href="https://use.fontawesome.com/releases/v6.6.0/css/all.css" rel="stylesheet">

  <style>
  </style>
</head>
<body>
  <section class="hero is-primary">

  <div class="hero-head">
  <nav class="navbar">
    <div class="container">
      <div class="navbar-brand">
        <a class="navbar-item" href="<%= @config['home'] %>">
          <span class="icon">
            <i class="fas fa-home"></i>
          </span>
        </a>
        <a class="navbar-item" href="https://github.com/htakeuchi/cheatsheet/ ">
          <span class="icon">
            <i class="fab fa-github""></i>
          </span>
        </a>
      </div>
    </div>
  </nav>
  </div>

  <div class="hero-body">
    <div class="container">
      <h1 class="title">
        <%= @config['title'] %>
      </h1>
      <h2 class="subtitle">
        <%= @config['description'] %>
      </h2>
    </div>
  </div>
  </section>

  <section class="section">
    <div class="container">
      <% category.sort.each do |cat| %>
        <div class="box">
          <h3 class="title is-3"><%= cat[0] %></h3>
          <div class="buttons">
            <% cat[1].each do |v| %>
              <span class="button is-info"><a href="<%= v[:filename].sub(/src\//, '').sub(/\.md$/, '.html') %>"><%= v[:title]%></a></span>
            <% end %>
          </div>
        </div>
        <% end %>
    </div>
  </section>

  <footer class="footer">
    <div class="content has-text-centered">
      <p>
      Copyright by <%= @config['author'] %>
      <% if @config['links']['site']['url'] %>
       ( <a href="<%= @config['links']['site']['url'] %>"><%= @config['links']['site']['title'] %></a> )
      <% end %>
      </p>
    </div>
    <nav class="navbar">
      <div class="container">
        <div class="navbar-brand">
          <% links = @config['links'] %>
          <% if links['email'] %>          
            <a class="navbar-item" href="mailto: <%= links['email'] %> ">
              <span class="icon">
                <i class="fa-solid fa-envelope"></i>
              </span>
            </a>
          <% end %>

          <% %w(bluesky mastodon threads github x).each do |sns| %>
          <% if links[sns] %>          
            <a class="navbar-item" href="<%= links[sns] %> ">
              <span class="icon">
                <i class="fab fa-<%= sns%>"></i>
              </span>
            </a>
          <% end %>
          <% end %>
        </div>
      </div>
    </nav>
  </footer>

</body>
</html>

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title><%= title %> cheatsheet</title>
  <meta name="description" content="<%= description%>" />

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bulma/0.7.2/css/bulma.min.css">
  <link rel="stylesheet" href="https://unpkg.com/bulmaswatch/cerulean/bulmaswatch.min.css">
  <style>
    table {
      font-size: small;
      width: 100%;
    }
    h1 {
      padding-bottom: 0.5em;
    }
    h2,h3,h4,h5,h6 {
      padding-top: 1em;
      padding-bottom: 0.2em;
      margin-top: 0.2em;
    }
    div.highlight {
      padding: 0.5em;
    }
  </style>
  <link href="https://use.fontawesome.com/releases/v6.6.0/css/all.css" rel="stylesheet">
  <script async type="text/javascript" src="/js/bulma.js"></script>
</head>
<body>
  <!-- Navigation bar -->
  <nav class="navbar is-fixed-top is-transparent">
    <div class="navbar-brand">
      <a class="navbar-item" href="<%= @config['home'] %>">
        <span class="icon">
          <i class="fas fa-home"></i>
        </span>
      </a>
      <a class="navbar-item" href="https://github.com/htakeuchi/cheatsheet/tree/master/src/<%= front_matter['html'].sub(/\.html$/, '.md') %>">
        <span class="icon">
          <i class="fab fa-github""></i>
        </span>
      </a>
    </div>
  </nav>

  <section class="section sheet padding-10m">
    <div class="container">
      <h1 class="title has-text-centered"><%= title %></h1>

      <div class="columns">
        <% columns.each do |a| %>
        <div class="column <%= column_class %>">
          <%= markdown.render a.join %>
        </div>
        <% end %>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="content has-text-centered">
      <p>
      Copyright by <%= @config['author'] %>
      <% if @config['links']['site']['url'] %>
       ( <a href="<%= @config['links']['site']['url'] %>"><%= @config['links']['site']['title'] %></a> )
      <% end %>
      </p>
    </div>
    <nav class="navbar">
      <div class="container">
        <div class="navbar-brand">
          <% links = @config['links'] %>
          <% if links['email'] %>          
            <a class="navbar-item" href="mailto: <%= links['email'] %> ">
              <span class="icon">
                <i class="fa-solid fa-envelope"></i>
              </span>
            </a>
          <% end %>

          <% %w(bluesky mastodon threads github x).each do |sns| %>
          <% if links[sns] %>          
            <a class="navbar-item" href="<%= links[sns] %> ">
              <span class="icon">
                <i class="fab fa-<%= sns%>"></i>
              </span>
            </a>
          <% end %>
          <% end %>
        </div>
      </div>
    </nav>
  </footer>

</body>
</html>
